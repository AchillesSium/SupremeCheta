# MongoDB Connection
MONGODB_URI=your_mongodb_connection_string_here

# Server Configuration
PORT=5001
NODE_ENV=development

# JWT Secrets (IMPORTANT: Generate new secrets for production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# JWT Token Expiry Times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Bcrypt Salt Rounds (higher = more secure but slower)
BCRYPT_SALT_ROUNDS=10

# Rate Limiting Configuration (in milliseconds)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5
REFRESH_RATE_LIMIT_WINDOW_MS=900000
REFRESH_RATE_LIMIT_MAX_REQUESTS=10
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX_REQUESTS=100

# Account Lockout Settings
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Security Configuration
MAX_CONCURRENT_SESSIONS=3
TOKEN_FAMILY_EXPIRY_DAYS=30

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual configuration
# 3. NEVER commit the .env file to git (it's in .gitignore)
# 4. Generate strong random secrets for JWT_ACCESS_SECRET and JWT_REFRESH_SECRET
