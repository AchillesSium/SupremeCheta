# Backend API URL
REACT_APP_API_URL=http://localhost:5001

# Token refresh timing (seconds before expiry to refresh)
REACT_APP_TOKEN_REFRESH_BUFFER=60

# Enable debug logging
REACT_APP_DEBUG=true

# App Environment
REACT_APP_ENV=development

# App Name
REACT_APP_NAME=Supreme Cheta

# Instructions:
# 1. Copy this file to .env
# 2. Update REACT_APP_API_URL to match your backend URL
# 3. Set REACT_APP_DEBUG=false in production
# 4. The .env file is gitignored and should not be committed
