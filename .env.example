# Server Configuration
PORT=5001
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/supreme_cheta
MONGODB_URI_TEST=mongodb://localhost:27017/supreme_cheta_test

# ============================
# JWT Configuration
# ============================
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_SECRET=your_64_char_hex_access_secret
JWT_REFRESH_SECRET=your_64_char_hex_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================
# Security Configuration
# ============================
MAX_CONCURRENT_SESSIONS=3
ENABLE_FINGERPRINTING=true
TOKEN_FAMILY_EXPIRY_DAYS=30
PASSWORD_RESET_EXPIRY_MINUTES=30
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# ============================
# Rate Limiting
# ============================
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_REFRESH_WINDOW_MS=900000
RATE_LIMIT_REFRESH_MAX=20

# ============================
# Account Security
# ============================
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128

# ============================
# Validation
# ============================
USERNAME_MIN_LENGTH=3
USERNAME_MAX_LENGTH=30
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128

# ============================
# Token Refresh (Frontend)
# ============================
TOKEN_PROACTIVE_REFRESH_SECONDS=60

# ============================
# Upload Configuration
# ============================
MAX_FILE_SIZE=5242880

# ============================
# Pagination Defaults
# ============================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ============================
# CORS & Origins
# ============================
CORS_ORIGIN=http://localhost:3000

# ============================
# Email Configuration
# ============================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@supremecheta.com

# ============================
# AWS S3 Configuration
# ============================
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_BUCKET_NAME=your_bucket_name
AWS_REGION=your_region

# ============================
# Payment Gateway
# ============================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ============================
# Social Authentication
# ============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
